                              "id": "2GyY6",
                              "name": "p2",
                              "fill": "#bac2de",
                              "textGrowth": "fixed-width",
                              "width": "fill_container",
                              "content": "理解似然函数是掌握最大似然估计(MLE)的关键。在实际应用中，我们通常使用对数似然来简化计算。",
                              "lineHeight": 1.6,
                              "fontFamily": "Inter",
                              "fontSize": 11,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "text",
                              "id": "sxYgb",
                              "name": "h4",
                              "fill": "#cdd6f4",
                              "content": "## 先验概率",
                              "fontFamily": "Inter",
                              "fontSize": 14,
                              "fontWeight": "600"

# ═══════════════════════════════════════════════════════════════════════════════
# Canvas Learning System — 根环境变量
# ═══════════════════════════════════════════════════════════════════════════════
#
# 使用方法:
#   1. cp .env.example .env
#   2. 编辑 .env，填入你的 vault 路径和 Neo4j 密码
#   3. docker-compose up -d
#
# ⚠️ 此文件为唯一真相源 — docker-compose.yml 通过 ${VAR:-default} 语法
#    自动读取此文件中的变量。backend/.env 中的同名变量应与此保持一致。
#
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Neo4j 图数据库 ───────────────────────────────────────────────────────────
# 存储知识图谱（概念节点、关系、学习事件）
# 首次启动时 Neo4j 用这组凭据初始化，之后更改需在 Neo4j Browser 里操作

# 用户名（默认 neo4j，通常不需要改）
NEO4J_USER=neo4j

# ⚠️ 必填：设置一个安全的密码（Neo4j 要求至少 8 位）
NEO4J_PASSWORD=

# 宿主机端口映射（避免与其他 Neo4j 实例冲突）
# HTTP Browser 端口（访问 http://localhost:${NEO4J_HTTP_PORT}）
NEO4J_HTTP_PORT=7478
# Bolt 协议端口（应用连接用）
NEO4J_BOLT_PORT=7691

# ─── Ollama 本地 LLM ──────────────────────────────────────────────────────────
# bge-m3 嵌入模型 + qwen3 推理模型
#
# Mac 用户：Ollama 通过 brew 原生安装运行（Metal GPU 加速）
#   brew install ollama && brew services start ollama
#   Docker 容器通过 host.docker.internal 访问宿主机 Ollama
#
# Windows/Linux 用户：使用 docker-compose --profile windows 启动容器版 Ollama

# Docker 容器内访问 Ollama 的地址
# Mac: http://host.docker.internal:11434（容器访问宿主机）
# Windows/Linux (Docker Ollama): http://ollama:11434（容器间通信）
OLLAMA_HOST=http://host.docker.internal:11434

# ─── Canvas Vault 路径（Story 1.8 多 Vault 支持）────────────────────────────
# VAULTS_ROOT: 包含所有 Obsidian vault 子目录的父目录
# ACTIVE_VAULT: 当前激活的 vault 子目录名（运行时可通过 API 切换）
#
# 目录结构示例:
#   VAULTS_ROOT/
#   ├── cs188/          ← 一个 vault（含 .obsidian/）
#   ├── cs61b/          ← 另一个 vault
#   └── operating-sys/  ← 第三个 vault
#
# 示例:
#   Mac:     /Users/yourname/Documents/vaults
#   Windows: C:\Users\yourname\Documents\vaults
#   Linux:   /home/yourname/Documents/vaults
#
# ⚠️ 必填：替换为你自己的路径
VAULTS_ROOT=

# 默认激活的 vault（该 vault 必须在 VAULTS_ROOT 下已存在）
ACTIVE_VAULT=canvas-vault

# 完整路径（= VAULTS_ROOT/ACTIVE_VAULT），自动派生，通常不需要手动设置
# 向后兼容：如果 VAULTS_ROOT 未设置，直接用此路径
CANVAS_BASE_PATH=

# Vault 挂载模式: rw（读写）或 ro（只读）
# 后端需要写入 frontmatter 元数据（掌握度、复习时间等），默认 rw
# 仅在你确定不需要后端写入时才改为 ro
VAULT_MOUNT_MODE=rw

# ─── API 配置 ─────────────────────────────────────────────────────────────────

# 后端 API 端口（默认 8001，避免与常见服务冲突）
API_PORT=8001

# CORS 允许的来源（逗号分隔）
# 包含 Obsidian 桌面应用 + 常见开发服务器地址
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173,http://tauri.localhost,app://obsidian.md

# 调试模式（启用 Swagger UI、详细错误信息；生产环境设为 false）
DEBUG=true

# ─── 开发工具（可选）──────────────────────────────────────────────────────────
# 以下变量仅在使用 docker-compose --profile dev 启动开发容器时需要

# Claude Dev 容器的 Anthropic API Key
# ANTHROPIC_API_KEY=

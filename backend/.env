# Canvas Learning System - CS188 Vault Configuration
# Generated for CS188 deployment

# ═══════════════════════════════════════════════════════════════════════════════
# Application Settings
# ═══════════════════════════════════════════════════════════════════════════════

PROJECT_NAME="Canvas Learning System API"
PROJECT_DESCRIPTION="Multi-agent learning system backend using Feynman method"
VERSION="1.0.0"
DEBUG=True
LOG_LEVEL="INFO"
DEBUG_AGENT_RESPONSE=true

# ═══════════════════════════════════════════════════════════════════════════════
# CORS Settings
# ═══════════════════════════════════════════════════════════════════════════════

CORS_ORIGINS="http://localhost:3000,http://127.0.0.1:3000,app://obsidian.md"

# ═══════════════════════════════════════════════════════════════════════════════
# Canvas Settings → CS188 Vault
# ═══════════════════════════════════════════════════════════════════════════════

CANVAS_BASE_PATH="C:/Users/Heishing/Desktop/spring course 2026/CS188"

# ═══════════════════════════════════════════════════════════════════════════════
# API Settings
# ═══════════════════════════════════════════════════════════════════════════════

API_V1_PREFIX="/api/v1"
MAX_CONCURRENT_REQUESTS=100

# ═══════════════════════════════════════════════════════════════════════════════
# AI Provider → Google Gemini
# ═══════════════════════════════════════════════════════════════════════════════

AI_PROVIDER=google
AI_API_KEY=AIzaSyCJnS1vK0fhpuGPBv30_5yOBv1k40fVewo
AI_MODEL_NAME=gemini-3.1-flash-lite-preview
AI_TIMEOUT=120

# ═══════════════════════════════════════════════════════════════════════════════
# Neo4j → 复用 neo4j-cs188 容器 (port 7688)
# ═══════════════════════════════════════════════════════════════════════════════

NEO4J_ENABLED=true
NEO4J_URI=bolt://localhost:7691
NEO4J_USER=neo4j
NEO4J_PASSWORD=cs188study
NEO4J_DATABASE=neo4j
NEO4J_MAX_CONNECTION_POOL_SIZE=50
NEO4J_CONNECTION_TIMEOUT=30
NEO4J_MAX_CONNECTION_LIFETIME=3600
NEO4J_RETRY_ATTEMPTS=3
NEO4J_RETRY_DELAY_BASE=1.0
NEO4J_RETRY_MAX_DELAY=10.0

# ═══════════════════════════════════════════════════════════════════════════════
# Graphiti JSON Dual-Write
# ═══════════════════════════════════════════════════════════════════════════════

ENABLE_GRAPHITI_JSON_DUAL_WRITE=true

# ═══════════════════════════════════════════════════════════════════════════════
# LanceDB Auto-Index
# ═══════════════════════════════════════════════════════════════════════════════

ENABLE_LANCEDB_AUTO_INDEX=true
LANCEDB_INDEX_DEBOUNCE_MS=500
LANCEDB_INDEX_TIMEOUT=5.0
LANCEDB_PATH=data/lancedb

# ═══════════════════════════════════════════════════════════════════════════════
# Vault-wide Note Indexing (Step 8)
# ═══════════════════════════════════════════════════════════════════════════════

VAULT_INDEX_ENABLED=true

# ═══════════════════════════════════════════════════════════════════════════════
# Agent Architecture Flags (Plan Step 6/7)
# ═══════════════════════════════════════════════════════════════════════════════

# Phase 4: React Agent (create_react_agent with autonomous retrieval)
# LLM autonomously decides when to search vault notes / knowledge graph
ENABLE_REACT_AGENT=true
# React Agent uses a stronger model for reliable tool calling
REACT_AGENT_MODEL=gemini-2.5-flash

# Phase 3: LangGraph Agent Graph (Adaptive + Corrective RAG) - not yet tested
# ENABLE_AGENT_GRAPH=false

# Phase 2: Gemini function calling with tool declarations
# ENABLE_TOOL_CALLING=false
